. /lib/functions/leds.sh

get_mac_label()
{
	local interface=$1
	local mac=$(cat /sys/class/net/${interface}/address)
	echo ${mac:9:8} | tr ':' '-'
}

board=$(board_name)

case "$board" in
*)
	;;
esac

