set_led_netdev_trigger() {
	local iface="$1"
	local led="$2"

	[ -d "/sys/class/net/$iface" ] && ucidef_set_led_netdev "$led" "$led" "$led" "$iface"
}

board_config_update
case "$(board_name)" in
acer,vero-w6m)
	ucidef_set_led_netdev "eth0link" "ETH0" "green:eth0" "eth0" "link"
	ucidef_set_led_netdev "eth1link" "ETH1" "green:eth1" "eth1" "link"
	;;
airpi,ap3000m)
	ucidef_set_led_netdev "eth0" "ETH0" "green:eth0" "eth0" "link tx rx"
	ucidef_set_led_netdev "eth1" "ETH1" "green:eth1" "eth1" "link tx rx"
	;;
arcadyan,mozart)
	ucidef_set_led_netdev "lan" "LAN" "green:lan" "eth0" "link tx rx"
	ucidef_set_led_netdev "wan" "WAN" "green:wan" "eth1" "link tx rx"
	;;
basizis,ax3000wm)
	ucidef_set_led_netdev "lanlink" "LANLINK" "green:lan" "eth0" "link"
	ucidef_set_led_netdev "wanlink" "WANLINK" "green:wan" "eth1" "link"
	;;
bazis,ax3000wm)
	ucidef_set_led_netdev "lanlink" "LANLINK" "green:lan" "eth1" "link"
	ucidef_set_led_netdev "internet" "internet" "blue:wan-online" "wan" "link"
	;;
beeconmini,seed-ac1)
	ucidef_set_led_netdev "wan" "WAN" "green:wan" "eth1" "link tx rx"
	;;
comfast,cf-xr186)
	ucidef_set_led_netdev "lan" "LAN" "blue:lan" "eth0" "link tx rx"
	ucidef_set_led_netdev "wlan2g" "WLAN2G" "green:wlan" "phy0-ap0" "link tx rx"
	ucidef_set_led_netdev "wlan5g" "WLAN5G" "green:wlan" "phy1-ap0" "link tx rx"
	;;
dlink,aquila-pro-ai-e30-a1|\
netis,eap930-v1)
	ucidef_set_interface_lan "lan"
	;;
glinet,gl-mt2500|\
glinet,gl-mt2500-airoha)
	ucidef_set_led_netdev "eth0" "ETH0" "green:eth0" "eth0" "link"
	;;
glinet,gl-mt6000)
	ucidef_set_led_netdev "eth0" "ETH0" "blue:eth0" "eth0" "link tx rx"
	ucidef_set_led_netdev "eth1" "ETH1" "blue:eth1" "eth1" "link tx rx"
	;;
glinet,gl-xe3000)
	ucidef_set_led_netdev "eth" "ETH" "blue:eth" "eth0" "link tx rx"
	;;
ignite,ai-box)
	ucidef_set_led_netdev "eth0" "ETH0" "green:eth0" "eth0" "link tx rx"
	ucidef_set_led_netdev "eth1" "ETH1" "green:eth1" "eth1" "link tx rx"
	;;
jcg,xk2000)
	ucidef_set_led_netdev "internet" "internet" "blue:internet" "wan" "link"
	;;
linksys,e8350-undo)
	ucidef_set_led_netdev "eth0" "ETH0" "green:eth0" "eth0" "link tx rx"
	ucidef_set_led_netdev "eth1" "ETH1" "green:eth1" "eth1" "link tx rx"
	;;
mercury,xd20)
	ucidef_set_led_netdev "internet" "internet" "blue:internet" "wan" "link tx rx"
	;;
tl,xp4945rev5)
	ucidef_set_led_netdev "eth0" "ETH0" "green:eth0" "eth0" "link tx rx"
	ucidef_set_led_netdev "eth1" "ETH1" "green:eth1" "eth1" "link tx rx"
	;;
unitech,tb-mt7981)
	ucidef_set_led_netdev "eth0" "ETH0" "green:eth0" "eth0" "link tx rx"
	;;
xiaomi,be3000-5g|\
xiaomi,mi-router-cr6606|\
xiaomi,mi-router-cr6609|\
xiaomi,mi-router-wr30u-stock)
	# Handled by a different script
	;;
esac
board_config_flush

exit 0