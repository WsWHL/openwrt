config_off_leds
config_generate_led_conf() {
	local key=$1
	local dev=$2
	local name="${key#*_}" # strip off the prefix
	local ledname="${name,,}" # convert to lowercase
	[ -d /sys/class/leds ] || return
	ucidef_set_led_netdev "$ledname" "$name" "*:$ledname" "$dev"
}

exit 0